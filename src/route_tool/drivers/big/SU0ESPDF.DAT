;The name in the braces indicates Section Name

;Comments [options:...]are included below each key in each section to know the different options for that command KEY.

[DEVMODEDATA]

;COLORMODE=Color
;Options: Mono,Color
SCALINGMODE=Software
;Only for X-Y zoom
;Options: Software, Hardware
DEVICETYPE=Color
;; Do not write JPEGPASSTHRU key. Control with DEVMODE value now
;JPEGPASSTHRU=TRUE

[COLORSPACE]

PCLXLVersion=30
;Options 20, 21, and 30

GrayCorrection=TRUE
;Options : TRUE, FALSE

ColorSpace=RGB
;Options sRGB, RGB

[BITMAPCOMPRESSION]
BitmapCompression=JPEG
;Options : DRC, JPEG 
JPEGQualityFactor=100
;Options 0 to 100

[ImageStamp]
;FileName=
DestSizeX=100
DestSizeY=100
Tiled=NO
FirstPageOnly=NO
Transparent=YES
ImageStampPosition=Center
;Options Center;left;Right;TopLeft;Top;TopRight;BottomLeft;Bottom;BottomRight;UserDefined;
PositionX=0
PositionY=0
